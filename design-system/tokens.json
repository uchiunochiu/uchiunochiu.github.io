{
  "$schema": "https://json.schemastore.org/style-dictionary",
  "meta": {
    "name": "Tachikoma Mobile DS",
    "version": "1.0.0"
  },
  "color": {
    "bg": {
      "base": "#F7F8FA",
      "surface": "#FFFFFF",
      "elevated": "#FFFFFF",
      "inverse": "#111317"
    },
    "text": {
      "primary": "#101216",
      "secondary": "#4F5967",
      "muted": "#7A8494",
      "inverse": "#F5F7FB"
    },
    "border": {
      "soft": "#E8ECF2",
      "strong": "#CAD2DE",
      "focus": "#1E66F5"
    },
    "brand": {
      "primary": "#FF2B52",
      "primaryHover": "#E91F47",
      "primaryPressed": "#CE173C",
      "onPrimary": "#FFFFFF"
    },
    "state": {
      "success": "#1E9E62",
      "warning": "#D48806",
      "danger": "#D92D20",
      "info": "#1E66F5"
    }
  },
  "spacing": {
    "0": 0,
    "1": 4,
    "2": 8,
    "3": 12,
    "4": 16,
    "5": 20,
    "6": 24,
    "8": 32,
    "10": 40,
    "12": 48,
    "16": 64
  },
  "radius": {
    "sm": 8,
    "md": 12,
    "lg": 16,
    "xl": 24,
    "pill": 999
  },
  "shadow": {
    "card": "0 4px 16px rgba(16,18,22,0.06)",
    "modal": "0 10px 30px rgba(16,18,22,0.14)"
  },
  "font": {
    "family": {
      "base": "'Noto Sans JP', 'Hiragino Kaku Gothic ProN', sans-serif",
      "accent": "'M PLUS 1p', 'Noto Sans JP', sans-serif",
      "numeric": "'IBM Plex Sans', 'Noto Sans JP', sans-serif"
    },
    "size": {
      "xs": 11,
      "sm": 13,
      "md": 15,
      "lg": 18,
      "xl": 22,
      "xxl": 28
    },
    "weight": {
      "regular": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700
    },
    "lineHeight": {
      "tight": 1.25,
      "normal": 1.5,
      "relaxed": 1.7
    }
  },
  "motion": {
    "duration": {
      "fast": "120ms",
      "base": "180ms",
      "slow": "240ms"
    },
    "easing": {
      "standard": "cubic-bezier(0.2, 0.8, 0.2, 1)",
      "emphasized": "cubic-bezier(0.2, 0.9, 0.15, 1)"
    }
  }
}
